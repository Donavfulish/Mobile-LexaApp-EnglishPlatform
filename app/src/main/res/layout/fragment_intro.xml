<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:clipToPadding="false">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <com.home.lexa.ui.components.PasswordInput
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/btnSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/passwordInput"
                android:text="Click me to switch Editable ON/OFF"/>

            <GridLayout
                android:id="@+id/cardGrid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true"
                app:layout_constraintTop_toBottomOf="@id/btnSwitch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.home.lexa.ui.components.FlashcardMini
                    android:id="@+id/card1"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp" />

                <com.home.lexa.ui.components.FlashcardMini
                    android:id="@+id/card2"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp" />

                <com.home.lexa.ui.components.FlashcardMini
                    android:id="@+id/card3"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp" />

                <com.home.lexa.ui.components.FlashcardMini
                    android:id="@+id/card4"
                    android:layout_width="175dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp" />

            </GridLayout>

            <TextView
                android:id="@+id/tvTitleLarge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thẻ chính của hôm nay"
                android:textSize="18sp"
                android:textColor="#111827"
                android:textStyle="bold"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@+id/cardGrid"
                app:layout_constraintStart_toStartOf="parent" />

            <com.home.lexa.ui.components.Flashcard
                android:id="@+id/mainFlashcard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitleLarge"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <com.home.lexa.ui.components.BottomNavigation
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>