<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:foreground="?attr/selectableItemBackground"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvIconBox"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:cardBackgroundColor="#F4F5FB"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivMainIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="#6A65E9" />
    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/ivOptions"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvTitle"
        app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
        app:srcCompat="@drawable/ic_more_horiz_24"
        app:tint="#888888" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:text="Tiếng Anh chuyên ngành IT"
        android:textColor="#202124"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/ivBook"
        app:layout_constraintEnd_toStartOf="@+id/ivOptions"
        app:layout_constraintStart_toEndOf="@+id/cvIconBox"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageView
        android:id="@+id/ivBook"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginTop="8dp"
        app:srcCompat="@drawable/ic_outline_book_ribbon"
        app:layout_constraintTop_toBottomOf="@+id/tvTitle"
        app:layout_constraintBottom_toTopOf="@+id/tagCategory"
        app:layout_constraintStart_toStartOf="@+id/tvTitle"
        app:tint="#888888" />

    <TextView
        android:id="@+id/tvWordCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:text="120 từ"
        android:textColor="#5F6368"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/ivBook"
        app:layout_constraintStart_toEndOf="@+id/ivBook"
        app:layout_constraintTop_toTopOf="@+id/ivBook" />

    <ImageView
        android:id="@+id/ivCalendar"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="16dp"
        android:src="@android:drawable/ic_menu_recent_history"
        app:layout_constraintBottom_toBottomOf="@+id/ivBook"
        app:layout_constraintStart_toEndOf="@+id/tvWordCount"
        app:layout_constraintTop_toTopOf="@+id/ivBook"
        app:tint="#888888" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:text="2 ngày trước"
        android:textColor="#5F6368"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/ivBook"
        app:layout_constraintStart_toEndOf="@+id/ivCalendar"
        app:layout_constraintTop_toTopOf="@+id/ivBook" />

    <com.home.lexa.ui.components.Tag
        android:id="@+id/tagCategory"
        android:layout_width="89dp"
        android:layout_height="28dp"
        android:layout_marginStart="72dp"
        android:layout_marginTop="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ivBook" />

</androidx.constraintlayout.widget.ConstraintLayout>